<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net462</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>Updater</AssemblyName>
    <RootNamespace>LanOra.Updater</RootNamespace>
    <ProjectGuid>{D4E5F6A7-B8C9-0123-DEF0-123456789003}</ProjectGuid>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- Windows 7 SP1 minimum -->
    <SupportedOSPlatformVersion>6.1</SupportedOSPlatformVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies.net462" Version="1.0.3" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <!-- Reference System.IO.Compression for zip extraction -->
    <Reference Include="System.IO.Compression" />
    <Reference Include="System.IO.Compression.FileSystem" />
  </ItemGroup>
</Project>
